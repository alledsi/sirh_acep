# Copier ce fichier vers .env et adapter les valeurs
# .env est ignoré par Git et ne doit JAMAIS être commité

# ========== Django ==========
# Générer une clé : python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=remplace-moi-par-une-cle-secrete-aleatoire-50-caracteres-minimum

DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ========== Base de données ==========
# Dev (SQLite) — recommandé pour démarrer
DATABASE_URL=sqlite:///db.sqlite3

# Prod (PostgreSQL) — décommenter et adapter
# DATABASE_URL=postgres://sirh_user:MOT_DE_PASSE@localhost:5432/sirh_acep

# ========== Sécurité (production uniquement) ==========
# SECURE_SSL_REDIRECT=True
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True

# ========== Pointage ==========
# Header HTTP pour récupérer l'IP réelle si derrière un reverse proxy (nginx)
# Mettre à False si Django est exposé directement (sans proxy)
USE_X_FORWARDED_FOR=True
